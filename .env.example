# Server
PORT=3000
HOST=0.0.0.0

# DashScope official API
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_ASYNC=true

# Planner (server-side only)
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=moonshotai/kimi-k2.5
KIMI_BASE_URL=https://integrate.api.nvidia.com/v1
KIMI_REQUEST_TIMEOUT_MS=60000
KIMI_RETRY_DELAY_MS=2500
KIMI_SCENE_BATCH_SIZE=2

# Media models
# Async text-to-image path: prefer qwen-image-plus, fall back to qwen-image.
IMAGE_MODEL=qwen-image-plus
IMAGE_MODEL_SEQUENCE=qwen-image-plus,qwen-image
VIDEO_RESOLUTION=720P
VIDEO_DURATION_SECONDS=15
ENABLE_EXAMPLE_CAPTURE=false
MAX_PRODUCTION_RUNS=3
PERSIST_ROOT=
# Native-audio 720P chain using the remaining Wan 2.6 family.
VIDEO_MODEL_SEQUENCE=wan2.6-i2v,wan2.6-i2v-flash

# Proxy rate control
IMAGE_CONCURRENCY=1
VIDEO_CONCURRENCY=2
API_CONCURRENCY=5
