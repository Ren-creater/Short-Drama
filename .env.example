# Server
PORT=3000
HOST=0.0.0.0

# DashScope official API
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_ASYNC=true

# Planner (server-side only)
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=moonshotai/kimi-k2.5
KIMI_BASE_URL=https://integrate.api.nvidia.com/v1

# Media models
IMAGE_MODEL=qwen-image
TTS_MODEL=qwen3-tts-flash
VIDEO_RESOLUTION=720P
VIDEO_DURATION_SECONDS=5
# 720P-capable fallback chain. wan2.2-i2v-plus is omitted because it does not offer 720P.
VIDEO_MODEL_SEQUENCE=wan2.1-i2v-plus,wan2.1-i2v-turbo,wan2.2-i2v-flash,wan2.5-i2v-preview,wan2.6-i2v,wan2.6-i2v-flash

# Proxy rate control
TTS_CONCURRENCY=2
IMAGE_CONCURRENCY=1
VIDEO_CONCURRENCY=2
API_CONCURRENCY=5
